NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (e-mailverzending bij offerteaanvragen)
# Maak een API-key aan op https://resend.com/api-keys en vul die hieronder in.
RESEND_API_KEY=
# Verzendadres. Het domein climate-x.nl moet geverifieerd zijn in Resend
# (Resend dashboard -> Domains -> DNS-records toevoegen) voordat dit werkt.
RESEND_FROM_EMAIL=ClimateX <offerte@climate-x.nl>
# E-mailadres waarop jij de interne notificatie ontvangt bij elke nieuwe aanvraag.
ADMIN_NOTIFICATION_EMAIL=ayhan-b@outlook.com

# Klantenportaal: service-role key (Supabase dashboard -> Settings -> API -> service_role).
# GEHEIM houden. Nooit met NEXT_PUBLIC_ prefixen. Alleen gebruikt in app/api/portal/invite/route.ts.
SUPABASE_SERVICE_ROLE_KEY=
# Gedeeld wachtwoord dat de CRM-beheerder moet invullen om een klantaccount aan te maken
# of een portal-uitnodiging te versturen vanuit het dashboard. Zelf instellen, GEHEIM houden.
PORTAL_ADMIN_SECRET=
