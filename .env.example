NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (e-mailverzending bij offerteaanvragen)
# Maak een API-key aan op https://resend.com/api-keys en vul die hieronder in.
RESEND_API_KEY=
# Verzendadres. Zonder geverifieerd eigen domein in Resend: gebruik het test-adres hieronder.
# Zodra je een domein (bijv. climatex.nl) hebt geverifieerd in Resend, verander je dit in
# bijvoorbeeld "ClimateX <offerte@climatex.nl>".
RESEND_FROM_EMAIL=ClimateX <onboarding@resend.dev>
# E-mailadres waarop jij de interne notificatie ontvangt bij elke nieuwe aanvraag.
ADMIN_NOTIFICATION_EMAIL=ayhan-b@outlook.com
